extends ../../layout/layout.pug

block variable
    -var path = '../../';


block content

    // begin firstscreen
    section#firstscreen.firstscreen.section
        
            .firstscreen__swiper
                .swiper.firstscreen_swiper_js
                    .swiper-wrapper
                        each item in [{img: '1', title: 'Объятия<br> вдали от дома', desc: 'Полотенца, халаты, тапочки'}, {img: '2', title: 'Изысканая забота', desc: 'Ежедневный уход'}, {img: '3', title: 'Ощущение комфорта', desc: 'Текстиль'},]
                            .swiper-slide 
                                .firstscreen__slide 
                                    .firstscreen__img.img
                                        img(src="../../../img/firstscreen_"+item.img+".webp", alt="")
                               
                                    .firstscreen__content
                                        h2.firstscreen__title!=item.title
                                        .firstscreen__desc
                                            p=item.desc
                                        .firstscreen__btn
                                            a.btn.btn_lg(href="") посмотреть

                    .swiper-pagination.firstscreen__pagination
                                    
                    .swiper-nav.firstscreen__nav
                        i.swiper-arrow.icon_arrow_left_sm
                        i.swiper-arrow.icon_arrow_right_sm

            
           
    
    // end firstscreen

    // begin topCategories
    section#topCategories.topCategories.section
        .container_center.container_center_sm
            h2.section__title Заголовок секции основных категорий
            .section__desc Описание секции основных категорий
            .section__wrap
                .topCategories__grid
                    each item in [{img: '1', title: 'Продукт 1'}, {img: '2', title: 'Продукт 2'}, {img: '3', title: 'Продукт 3'}, ]
                        a.topCategories__item(href="#")
                            .topCategories__img.img
                                img(src="../../../img/firstscreen_"+item.img+".webp", alt="")
                            .topCategories__title!=item.title

            .section__btn 
                a.btn(href="#") Кнопка секции
              
    
    // end topCategories

    // begin homeProducts
    section#homeProducts.homeProducts.section
        .container_center
            h2.section__title Каталог товаров
            .section__desc Описание секции, если нужно
            .section__wrap
                .product__grid
                    include ../../products/product.pug
                    //- include ../products/productOfStock.pug
                    //- include ../products/productSell.pug
                    //- include ../products/product.pug
                    //- include ../products/product.pug

                    //- include ../products/pagination.pug
            .section__btn 
                a.btn(href="#") Все товары
               
    
    // end homeProducts

    // begin media
    section#mediaSlider.media.media_swiper.section
        .container_center
            .media__layout
               
                .swiper.media_swiper_js
                    .swiper-wrapper.counter-wrap 
                        each item in [1,2,3,1,2,3]
                            .swiper-slide.counter-item
                                .media__thumbnail
                                    .media__img.img
                                        img(src="../../../img/firstscreen_"+item+".webp" alt="" loading="lazy")

                                    .media__label
                                        span.counter-el  &mdash;  Спальня
                                        p Внутренний мир


                    .swiper-nav.media__nav.desktop
                        i.swiper-arrow.icon_arrow_left_sm
                        i.swiper-arrow.icon_arrow_right_sm

                    .swiper-pagination.media__pagination
                   
                .media__content
                    h2.section__title.ta_l Красивые номеров для вдохновения
                    .section__content.ta_l
                        p Наш дизайнер уже сделал множество красивых прототипов комнат, которые вас вдохновляют.
                        
                    .section__btn.ta_l
                        a.btn(href="#") кнопка

    // end media

    // begin hscroll
    section#hscroll.hscroll.section
        .hscroll__head
            h2.section__title # Заголовок секции 
            //- .section__desc Описание секции
        .hscroll__content
            .swiper.hscroll_swiper_js
                .swiper-wrapper
                    //- each item in [{img: "1"}, {img: "2"}, {img: "3"}, {img: "1"}, {img: "2"}, {img: "3"}, {img: "1"}, {img: "2"}, {img: "3"}, {img: "1"}, {img: "2"}, {img: "3"}, ]
                    each item in [1,2,3,4]
                        .swiper-slide.no_interaction
                            each img in [{img: "1"}, {img: "2"}, {img: "3"}, {img: "1"}, {img: "2"}, {img: "3"}, {img: "1"}, {img: "2"}, {img: "3"}  ]
                                .hscroll__img.img
                                    img(src="../../../img/firstscreen_"+img.img+".webp", alt="")

        //- .section__btn 
        //-     a.btn(href="#") кнопка

    
    // end hscroll

    // begin partners
    section#partners.partners.section
        .container_center
            .partners__content
                h2.section__title Заголовок

                .section__desc Описание секции 
                .partners__swiper
                    .swiper.partners_swiper_js
                        .swiper-wrapper
                            each item in ['Гостиница 1','Гостиница 2','Гостиница 3','Гостиница 4','Гостиница 5','Гостиница 6']
                                .swiper-slide.partners__slide
                                    .partners__title=item
                                    .partners__desc короткое описание
                                
                        //- .swiper-nav.partners__nav.desktop
                        //-     i.swiper-arrow.icon_arrow_left_sm
                        //-     i.swiper-arrow.icon_arrow_right_sm

                        .swiper-pagination.partners__pagination
           
                .section__btn
                        a.btn(href="#") кнопка
    
    // end partners

    // begin banner
    section#banner.banner.section
        .container_center
            .banner__swiper
                .swiper.banner_swiper_js
                    .swiper-wrapper
                        each item in [1,2]
                            .swiper-slide.banner__slide
                                .banner__img.img
                                    img(src="../../../img/firstscreen_"+item+".webp", alt="")
                                .banner__content
                                    h2.banner__title.ta_l Лучшие скидки
                                    .banner__desc.ta_l Lorem ipsum dolor sit amet, animal utamur id nec, clita doming oblique usu cu, utroque omittam ex sea inani eleifend.
                                    .section__btn.ta_l 
                                        a.btn(href="#") перейти

                    .swiper-nav.banner__nav.desktop
                        i.swiper-arrow.icon_arrow_left_sm
                        i.swiper-arrow.icon_arrow_right_sm

                .swiper-pagination.banner__pagination.mobile
            

    
    // end banner

